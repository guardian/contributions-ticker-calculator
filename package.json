{
  "name": "ticker-calculator",
  "version": "1.0.0",
  "private": true,
  "buildDir": "./target",
  "scripts": {
    "lint": "eslint 'src/**/*.ts'",
    "prettier:check": "prettier --check ./src",
    "prettier:fix": "prettier --write ./src",
    "build": "esbuild src/lambda.ts src/local.ts --bundle --platform=node --outdir=target",
    "local": "Stage=CODE ts-node ./src/local.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-ssm": "^3.600.0",
    "@aws-sdk/lib-storage": "^3.600.0",
    "@google-cloud/bigquery": "8.1.1",
    "google-auth-library": "^10.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@guardian/eslint-config-typescript": "^1.0.2",
    "@guardian/prettier": "^1.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/node-fetch": "~2.6.2",
    "esbuild": "0.28.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^2.7.1",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^4.7.4"
  },
  "packageManager": "pnpm@10.33.0"
